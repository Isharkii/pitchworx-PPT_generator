# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/pitchworx

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Gamma API ─────────────────────────────────────────────────────────────────
# Get your key at https://gamma.app/settings/api-keys (Pro/Ultra/Teams/Business)
GAMMA_API_KEY=your_gamma_api_key_here

# ── AWS S3 (for PPTX storage) ─────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=pitchworx-presentations
