generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  projects Project[]

  @@map("users")
}

// ─── Themes ───────────────────────────────────────────────────────────────────

model Theme {
  id           String  @id @default(uuid())
  name         String
  config       Json    // { colors, fonts, layouts }
  previewImage String? @map("preview_image")

  projects Project[]

  @@map("themes")
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  themeId   String?  @map("theme_id")
  theme     Theme?   @relation(fields: [themeId], references: [id])
  title     String
  status    String   @default("draft") // draft | generating | completed | failed
  createdAt DateTime @default(now()) @map("created_at")

  presentations  Presentation[]
  generationJobs GenerationJob[]

  @@map("projects")
}

// ─── Presentations ────────────────────────────────────────────────────────────

model Presentation {
  id            String   @id @default(uuid())
  projectId     String   @map("project_id")
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gammaResponse Json?    @map("gamma_response") // raw Gamma API output
  fileUrl       String?  @map("file_url")        // S3 URL of PPTX
  gammaUrl      String?  @map("gamma_url")        // Gamma viewer URL
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")

  slides Slide[]

  @@map("presentations")
}

// ─── Slides (editable structured data) ────────────────────────────────────────

model Slide {
  id             String       @id @default(uuid())
  presentationId String       @map("presentation_id")
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  slideIndex     Int          @map("slide_index")
  content        Json         // { title, bullets, font, imageUrl, ... }

  @@map("slides")
}

// ─── Generation Jobs ──────────────────────────────────────────────────────────

model GenerationJob {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      String   @default("queued") // queued | running | done | failed
  inputPrompt String   @map("input_prompt")
  numCards    Int      @default(8) @map("num_cards")
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("generation_jobs")
}
