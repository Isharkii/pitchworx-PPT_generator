# ── Gamma API (direct mode — no backend server) ────────────────────────────────
# Get your key at https://gamma.app/settings/api-keys (Pro/Ultra/Teams/Business)
GAMMA_API_KEY=your_gamma_api_key_here

# ── Backend mode (Fastify server) ─────────────────────────────────────────────
# If set, Next.js proxies generate requests to your Fastify backend.
# Leave blank to call Gamma directly from Next.js.
BACKEND_URL=http://localhost:3001
